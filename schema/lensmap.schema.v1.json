{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lensmap.dev/schema/lensmap.v1.json",
  "title": "LensMap Document v1",
  "type": "object",
  "required": [
    "type",
    "version",
    "mode",
    "covers",
    "anchors",
    "entries"
  ],
  "properties": {
    "type": {
      "const": "lensmap"
    },
    "version": {
      "type": "string",
      "pattern": "^1\\.0\\.0$"
    },
    "mode": {
      "type": "string",
      "enum": [
        "group",
        "file"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "covers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "anchors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/anchor"
      }
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entry"
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "positioning": {
          "type": [
            "string",
            "null"
          ]
        },
        "boilerplate_scope": {
          "type": [
            "string",
            "null"
          ]
        },
        "artifact_layers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "editor_anchor_visibility": {
          "type": [
            "string",
            "null"
          ]
        },
        "policy": {
          "type": "object",
          "properties": {
            "require_owner": {
              "type": "boolean"
            },
            "require_author": {
              "type": "boolean"
            },
            "require_template": {
              "type": "boolean"
            },
            "require_review_status": {
              "type": "boolean"
            },
            "stale_after_days": {
              "type": "integer",
              "minimum": 0
            },
            "required_patterns": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true,
  "$defs": {
    "anchor": {
      "type": "object",
      "required": [
        "id",
        "file"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-F0-9]{6,16}$"
        },
        "file": {
          "type": "string",
          "minLength": 1
        },
        "symbol": {
          "type": [
            "string",
            "null"
          ]
        },
        "symbol_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "line_anchor": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "line_symbol": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "span_start": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "span_end": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "fingerprint": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-f0-9]{12}$"
        },
        "signature_text": {
          "type": [
            "string",
            "null"
          ]
        },
        "placement": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "inline",
            "standalone",
            null
          ]
        },
        "updated_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      },
      "additionalProperties": true
    },
    "entry": {
      "type": "object",
      "required": [
        "ref",
        "file"
      ],
      "properties": {
        "ref": {
          "type": "string",
          "pattern": "^[A-F0-9]{6,16}-[0-9]+(?:-[0-9]+)?$"
        },
        "file": {
          "type": "string",
          "minLength": 1
        },
        "anchor_id": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[A-F0-9]{6,16}$"
        },
        "kind": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "comment",
            "doc",
            "todo",
            "decision",
            null
          ]
        },
        "text": {
          "type": [
            "string",
            "null"
          ]
        },
        "title": {
          "type": [
            "string",
            "null"
          ]
        },
        "owner": {
          "type": [
            "string",
            "null"
          ]
        },
        "author": {
          "type": [
            "string",
            "null"
          ]
        },
        "scope": {
          "type": [
            "string",
            "null"
          ]
        },
        "template": {
          "type": [
            "string",
            "null"
          ]
        },
        "review_status": {
          "type": [
            "string",
            "null"
          ]
        },
        "review_due_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "updated_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "created_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "source": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    }
  }
}
