{
  "name": "lensmap-vscode",
  "displayName": "%lensmap.displayName%",
  "description": "%lensmap.description%",
  "version": "0.3.0",
  "publisher": "protheuslabs",
  "license": "MIT",
  "homepage": "https://github.com/protheuslabs/Lensmap",
  "repository": {
    "type": "git",
    "url": "https://github.com/protheuslabs/Lensmap.git",
    "directory": "editor/vscode"
  },
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "lensmap",
    "documentation",
    "annotations",
    "code-intelligence"
  ],
  "activationEvents": [
    "onCommand:lensmap.showFileNotes",
    "onCommand:lensmap.annotateAtCursor",
    "onCommand:lensmap.refreshSidebar",
    "onCommand:lensmap.searchWorkspaceNotes",
    "onCommand:lensmap.revealEntry",
    "onView:lensmapSidebar",
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:python",
    "onLanguage:rust",
    "onLanguage:go",
    "onLanguage:java",
    "onLanguage:c",
    "onLanguage:cpp",
    "onLanguage:csharp",
    "onLanguage:kotlin"
  ],
  "main": "./extension.js",
  "files": [
    "extension.js",
    "package.json",
    "package.nls.json",
    "package.nls.zh-cn.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "package:vsix": "vsce package --out ../../artifacts/lensmap-vscode-${npm_package_version}.vsix"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.2"
  },
  "contributes": {
    "commands": [
      {
        "command": "lensmap.showFileNotes",
        "title": "%command.showFileNotes%"
      },
      {
        "command": "lensmap.annotateAtCursor",
        "title": "%command.annotateAtCursor%"
      },
      {
        "command": "lensmap.refreshSidebar",
        "title": "%command.refreshSidebar%"
      },
      {
        "command": "lensmap.searchWorkspaceNotes",
        "title": "%command.searchWorkspaceNotes%"
      },
      {
        "command": "lensmap.revealEntry",
        "title": "%command.revealEntry%"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "lensmapSidebar",
          "name": "%view.sidebar%"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "lensmap.refreshSidebar",
          "when": "view == lensmapSidebar",
          "group": "navigation@1"
        },
        {
          "command": "lensmap.searchWorkspaceNotes",
          "when": "view == lensmapSidebar",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "%lensmap.displayName%",
      "properties": {
        "lensmap.command": {
          "type": "string",
          "default": "",
          "description": "%config.command.description%"
        },
        "lensmap.extraArgs": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "%config.extraArgs.description%"
        }
      }
    }
  }
}
